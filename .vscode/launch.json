{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🐛 Debug API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "/workspace/backend/bin/Debug/net10.0/HongarijePlanner.Api.dll",
      "args": [],
      "cwd": "/workspace/backend",
      "stopAtEntry": false,
