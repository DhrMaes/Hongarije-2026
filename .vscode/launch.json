        "ConnectionStrings__DefaultConnection": "Host=db;Port=5432;Database=hongarije;Username=hongarije;Password=hongarije_dev"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/backend"
      }
    }
  ]
}
